# Production Environment Configuration
# Copy this file to .env and update values as needed

# Backend
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://planningpoker:planningpoker@postgres:5432/planningpoker?schema=public

# Frontend (used in development only, in production uses relative URLs)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# PostgreSQL (used by docker-compose)
POSTGRES_USER=planningpoker
POSTGRES_PASSWORD=planningpoker
POSTGRES_DB=planningpoker
